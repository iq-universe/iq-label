---
import Layout from '../../layouts/Layout.astro';
import JanguIcon from '../../components/icons/JanguIcon.astro';
import BukIcon from '../../components/icons/BukIcon.astro';
import GayageumIcon from '../../components/icons/GayageumIcon.astro';
import HaegeumIcon from '../../components/icons/HaegeumIcon.astro';
import DansoIcon from '../../components/icons/DansoIcon.astro';
import GeomungoIcon from '../../components/icons/GeomungoIcon.astro';
import tracksData from '../../data/tracks.json';
import genresData from '../../data/genres.json';
import type { Track, Genre } from '../../types';

export async function getStaticPaths() {
  const genres = genresData as Genre[];
  return genres.map((genre) => ({
    params: { slug: genre.slug },
    props: { genre },
  }));
}

interface Props {
  genre: Genre;
}

const { genre } = Astro.props;
const tracks = (tracksData as Track[]).filter((t) => t.genre === genre.slug);

const iconMap: Record<string, any> = {
  janggu: JanguIcon,
  buk: BukIcon,
  gayageum: GayageumIcon,
  haegeum: HaegeumIcon,
  danso: DansoIcon,
  geomungo: GeomungoIcon,
};
const Icon = iconMap[genre.instrument] || JanguIcon;
---

<Layout title={`${genre.label} — iq-label`}>
  <div style="max-width: 760px; margin: 0 auto; padding: 56px 24px;">
    <div class="tag" style="margin-bottom: 12px;">GENRE / 장르</div>

    <div style="display: flex; align-items: flex-end; gap: 18px; margin-bottom: 32px;">
      <div style="color: var(--color-ink);">
        <Icon size={56} strokeWidth={1.1} />
      </div>
      <div>
        <h1 class="serif" style="font-size: 38px; font-weight: 500; margin: 0; line-height: 1;">
          {genre.instrument_label_ko}
        </h1>
        <div class="mono" style="font-size: 12px; color: var(--color-ink-faded); margin-top: 6px;">
          {genre.label} · {genre.track_count} {genre.track_count === 1 ? 'track' : 'tracks'}
        </div>
      </div>
    </div>

    {
      tracks.length === 0 ? (
        <p style="color: var(--color-ink-faded);" class="serif">
          아직 트랙이 없습니다.
        </p>
      ) : (
        <div style="display: flex; flex-direction: column;">
          {tracks.map((track, i) => (
            <a
              href={`/track/${track.id}`}
              style={`display: flex; align-items: center; gap: 16px; padding: 20px 0; border-top: 1px solid var(--color-border); ${i === tracks.length - 1 ? 'border-bottom: 1px solid var(--color-border);' : ''}`}
            >
              <span class="mono" style="font-size: 11px; color: var(--color-ink-faded); min-width: 32px; letter-spacing: 0.1em;">
                {track.number}
              </span>
              <div style="flex: 1; min-width: 0;">
                <div class="serif" style="font-size: 18px; font-weight: 500; line-height: 1.3;">
                  {track.title_ko}
                </div>
                <div class="mono" style="font-size: 10px; color: var(--color-ink-faded); margin-top: 4px; letter-spacing: 0.05em;">
                  {track.fusion_with_label} ⊗ {track.genre}
                </div>
              </div>
              <span class="mono" style="font-size: 11px; color: var(--color-ink-faded);">
                {track.duration_label}
              </span>
            </a>
          ))}
        </div>
      )
    }
  </div>
</Layout>
