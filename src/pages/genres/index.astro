---
import Layout from '../../layouts/Layout.astro';
import GenreGrid from '../../components/GenreGrid.astro';
import genresData from '../../data/genres.json';
import type { Genre } from '../../types';

const genres = genresData as Genre[];
---

<Layout title="Genres — Label Q">
  <div style="max-width: 760px; margin: 0 auto; padding: 56px 24px 0;">
    <div class="tag" style="margin-bottom: 12px;">ALL GENRES / 전체 장르</div>
    <h1
      class="serif glow-cream"
      style="font-size: 38px; font-weight: 500; margin: 0 0 8px; line-height: 1.05;"
    >
      장르 목록
    </h1>
    <p
      style="margin: 0 0 28px; color: var(--color-text-secondary); font-style: italic; font-size: 15px;"
    >
      모든 트랙은 한국 전통악기와 현대 장르의 조합입니다.
    </p>
  </div>
  <GenreGrid genres={genres} showHeading={false} />
</Layout>
