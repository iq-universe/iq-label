---
import Layout from '../../layouts/Layout.astro';
import Waveform from '../../components/Waveform.astro';
import VibeNotes from '../../components/VibeNotes.astro';
import tracksData from '../../data/tracks.json';
import type { Track } from '../../types';

export async function getStaticPaths() {
  const tracks = tracksData as Track[];
  return tracks.map((track) => ({
    params: { id: track.id },
    props: { track },
  }));
}

interface Props {
  track: Track;
}

const { track } = Astro.props;
const trackJson = JSON.stringify(track);
---

<Layout title={`${track.title_ko} — iq-label`}>
  <div style="max-width: 760px; margin: 0 auto;">
    <div
      style="padding: 12px 24px; border-bottom: 0.5px solid var(--color-border); display: flex; align-items: center; gap: 8px; color: var(--color-text-secondary); font-size: 13px;"
    >
      <a href={`/genre/${track.genre}`} style="display: flex; align-items: center; gap: 8px;">
        ← back to {track.genre}
      </a>
    </div>

    <div style="display: grid; grid-template-columns: 200px 1fr; gap: 24px; padding: 28px 24px;">
      <div
        style="aspect-ratio: 1; background: var(--color-accent-bg); border-radius: var(--radius-md); padding: 14px; display: flex; flex-direction: column; justify-content: space-between; box-sizing: border-box;"
      >
        <div class="mono" style="font-size: 11px; color: var(--color-accent); opacity: 0.8;">
          no. {track.number}
        </div>
        <div>
          <div class="mono" style="font-size: 11px; color: var(--color-accent);">
            {track.genre} ⊗ {track.fusion_with}
          </div>
          <div
            class="mono"
            style="font-size: 11px; color: var(--color-accent); opacity: 0.7; margin-top: 2px;"
          >
            {track.published_at.slice(0, 4)}
          </div>
        </div>
      </div>

      <div style="min-width: 0;">
        <div class="tag" style="margin-bottom: 8px;">{track.genre} / no. {track.number}</div>
        <h1 class="serif" style="font-size: 28px; font-weight: 500; margin: 0 0 4px; line-height: 1.2;">
          {track.title_ko}
        </h1>
        <div class="muted" style="font-size: 14px; margin-bottom: 16px;">{track.title_en}</div>
        <div class="mono muted" style="font-size: 13px; margin-bottom: 6px;">
          {track.genre}<span class="fusion-op">⊗</span>{track.fusion_with}
        </div>
        <div class="mono tertiary" style="font-size: 12px; margin-bottom: 18px;">
          {track.duration_label} · {track.bpm} bpm · {track.key}
        </div>
        <button data-track={trackJson} style="display: inline-flex; align-items: center; gap: 8px;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"
            ><path d="M8 5v14l11-7z"></path></svg
          >
          Play
        </button>
      </div>
    </div>

    <div style="padding: 0 24px 22px;">
      <Waveform trackId={track.id} />
      <div style="display: flex; justify-content: space-between; margin-top: 4px;">
        <span class="mono tertiary" style="font-size: 11px;">0:00</span>
        <span class="mono tertiary" style="font-size: 11px;">{track.duration_label}</span>
      </div>
    </div>

    <VibeNotes notes={track.vibe_notes} />

    <details style="border-top: 0.5px solid var(--color-border);">
      <summary
        style="padding: 16px 24px; display: flex; justify-content: space-between; align-items: center; cursor: pointer; list-style: none;"
      >
        <div>
          <div class="tag" style="margin-bottom: 4px;">generation</div>
          <div class="mono muted" style="font-size: 13px;">
            {track.generation.candidate_count} candidates · {track.generation.selected} selected · {track.generation.tool}
          </div>
        </div>
        <span class="tertiary" style="font-size: 18px;">▾</span>
      </summary>
      <div style="padding: 0 24px 22px; color: var(--color-text-secondary); font-size: 14px;">
        <p>이 트랙은 <strong>{track.generation.tool}</strong> 으로 {track.generation.candidate_count}개 후보를 생성하고, 그중 {track.generation.selected}곡을 선별했습니다.</p>
        {
          track.reference_artists.length > 0 && (
            <p>
              참고 아티스트:{' '}
              {track.reference_artists.map((a, i) => (
                <span>
                  {i > 0 ? ', ' : ''}
                  <span class="mono">{a}</span>
                </span>
              ))}
            </p>
          )
        }
        <p class="tertiary" style="font-size: 12px;">License: {track.license}</p>
      </div>
    </details>
  </div>
</Layout>
