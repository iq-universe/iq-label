---
import Layout from '../../layouts/Layout.astro';
import Waveform from '../../components/Waveform.astro';
import VibeNotes from '../../components/VibeNotes.astro';
import Stamp from '../../components/Stamp.astro';
import JanguIcon from '../../components/icons/JanguIcon.astro';
import BukIcon from '../../components/icons/BukIcon.astro';
import GayageumIcon from '../../components/icons/GayageumIcon.astro';
import HaegeumIcon from '../../components/icons/HaegeumIcon.astro';
import DansoIcon from '../../components/icons/DansoIcon.astro';
import GeomungoIcon from '../../components/icons/GeomungoIcon.astro';
import tracksData from '../../data/tracks.json';
import type { Track } from '../../types';

export async function getStaticPaths() {
  const tracks = tracksData as Track[];
  return tracks.map((track) => ({
    params: { id: track.id },
    props: { track },
  }));
}

interface Props {
  track: Track;
}

const { track } = Astro.props;
const trackJson = JSON.stringify(track);

const iconMap: Record<string, any> = {
  janggu: JanguIcon,
  buk: BukIcon,
  gayageum: GayageumIcon,
  haegeum: HaegeumIcon,
  danso: DansoIcon,
  geomungo: GeomungoIcon,
};
const InstrumentIcon = iconMap[track.fusion_instrument] || JanguIcon;
---

<Layout title={`${track.title_ko} — Label Q`}>
  <article class="track-detail">
    <a class="mono track-back" href={`/genre/${track.genre}`}>
      ← {track.genre}
    </a>

    <section class="track-stage">
      <div class="stage-flow stage-flow-1" aria-hidden="true"></div>
      <div class="stage-flow stage-flow-2" aria-hidden="true"></div>

      <aside class="artifact-card">
        <div class="mono card-number">NO. {track.number}</div>
        <div class="instrument-field">
          <span class="instrument-ring instrument-ring-1" aria-hidden="true"></span>
          <span class="instrument-ring instrument-ring-2" aria-hidden="true"></span>
          <div class="instrument-symbol">
            <InstrumentIcon size={78} strokeWidth={0.9} />
          </div>
        </div>
        <div class="card-caption">
          <div class="serif card-title">{track.fusion_with_label}</div>
          <div class="mono card-year">{track.published_at.slice(0, 4)}</div>
        </div>
        <div class="stamp-wrap">
          <Stamp text={track.number} size={34} rotate={-6} />
        </div>
      </aside>

      <div class="track-copy">
        <div class="mono track-kicker">
          <span>{track.genre}</span>
          <span>{track.bpm} bpm</span>
          <span>{track.key}</span>
        </div>
        <h1 class="serif glow-cream track-title">
          {track.title_ko}
        </h1>
        <div class="track-subtitle">
          {track.title_en}
        </div>
        <div class="mono track-meta">
          <InstrumentIcon size={18} />
          <span class="serif instrument-name">
            {track.fusion_with_label}
          </span>
          <span class="fusion-op">⊗</span>
          <span>{track.genre}</span>
          <span class="meta-dot">·</span>
          <span>{track.duration_label}</span>
        </div>
        <button class="track-play" data-track={trackJson}>
          <span class="play-disc">▶</span>
          <span class="play-label">PLAY</span>
          <span class="play-bars" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
          </span>
        </button>
      </div>
    </section>

    <section class="wave-section">
      <Waveform trackId={track.id} />
      <div class="wave-times">
        <span class="mono">0:00</span>
        <span class="mono">
          {track.duration_label}
        </span>
      </div>
    </section>

    <VibeNotes notes={track.vibe_notes} />
  </article>

  <style>
    .track-detail {
      max-width: 1080px;
      margin: 0 auto;
      padding: 0 32px 86px;
      position: relative;
      z-index: 1;
    }

    .track-back {
      display: inline-flex;
      align-items: center;
      margin: 22px 0 36px;
      color: var(--color-text-faded);
      font-size: 12px;
      letter-spacing: 0.12em;
    }

    .track-back:hover {
      color: var(--color-dancheong-red);
    }

    .track-stage {
      position: relative;
      display: grid;
      grid-template-columns: minmax(220px, 290px) minmax(0, 1fr);
      gap: clamp(30px, 5vw, 66px);
      align-items: center;
      overflow: hidden;
      padding: 22px 0 34px;
      isolation: isolate;
    }

    .track-stage::before {
      content: '';
      position: absolute;
      left: 9%;
      right: 0;
      top: 53%;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(232, 72, 82, 0.42), rgba(242, 234, 216, 0.08), transparent);
      opacity: 0.6;
      transform: translateY(-50%);
    }

    .stage-flow {
      position: absolute;
      z-index: -1;
      width: 34%;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(232, 72, 82, 0.75), transparent);
      opacity: 0;
      transform: rotate(-18deg) translateX(-80%);
      animation: stage-flow 5.6s ease-in-out infinite;
    }

    .stage-flow-1 {
      top: 32%;
      left: 28%;
    }

    .stage-flow-2 {
      top: 72%;
      left: 18%;
      animation-delay: 2s;
    }

    .artifact-card {
      position: relative;
      min-height: 286px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      overflow: hidden;
      padding: 22px;
      border: 0.5px solid var(--color-border-strong);
      background:
        radial-gradient(circle at 75% 78%, rgba(232, 72, 82, 0.14), transparent 34%),
        linear-gradient(180deg, rgba(242, 234, 216, 0.04), transparent 42%),
        rgba(22, 18, 31, 0.58);
      box-shadow:
        inset 0 1px 0 rgba(242, 234, 216, 0.04),
        0 24px 70px rgba(10, 6, 18, 0.18);
      backdrop-filter: blur(6px);
    }

    .artifact-card::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(120deg, transparent 20%, rgba(242, 234, 216, 0.09), transparent 62%);
      transform: translateX(-120%);
      animation: card-sheen 5.8s ease-in-out infinite;
    }

    .card-number,
    .card-year {
      color: var(--color-text-faded);
    }

    .card-number {
      position: relative;
      z-index: 1;
      font-size: 11px;
      letter-spacing: 0.16em;
    }

    .instrument-field {
      position: relative;
      z-index: 1;
      min-height: 132px;
      display: grid;
      place-items: center;
      color: var(--color-text-primary);
    }

    .instrument-ring {
      position: absolute;
      width: 116px;
      height: 116px;
      border-radius: 50%;
      border: 1px solid rgba(232, 72, 82, 0.22);
      animation: instrument-ring 4.8s ease-out infinite;
    }

    .instrument-ring-2 {
      animation-delay: 1.65s;
    }

    .instrument-symbol {
      transform-origin: center;
      filter: drop-shadow(0 0 20px rgba(242, 234, 216, 0.12));
      animation: instrument-float 2.8s ease-in-out infinite;
    }

    .card-caption {
      position: relative;
      z-index: 1;
    }

    .card-title {
      color: var(--color-text-primary);
      font-size: 20px;
      font-weight: 500;
      line-height: 1.2;
    }

    .card-year {
      margin-top: 4px;
      font-size: 10px;
    }

    .stamp-wrap {
      position: absolute;
      right: 16px;
      bottom: 16px;
      z-index: 1;
      animation: stamp-bounce 3.2s ease-in-out infinite;
    }

    .track-copy {
      position: relative;
      min-width: 0;
    }

    .track-kicker {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 16px;
      color: var(--color-text-faded);
      font-size: 11px;
      letter-spacing: 0.13em;
      text-transform: uppercase;
    }

    .track-kicker span {
      border: 0.5px solid rgba(184, 171, 148, 0.22);
      padding: 4px 8px;
      background: rgba(22, 18, 31, 0.32);
    }

    .track-title {
      margin: 0 0 10px;
      font-size: clamp(44px, 6vw, 70px);
      font-weight: 500;
      line-height: 0.98;
    }

    .track-subtitle {
      margin-bottom: 26px;
      color: var(--color-text-secondary);
      font-size: 19px;
      font-style: italic;
    }

    .track-meta {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 10px;
      margin-bottom: 28px;
      color: var(--color-text-secondary);
      font-size: 13px;
    }

    .instrument-name {
      color: var(--color-text-primary);
      font-size: 15px;
      letter-spacing: 0;
    }

    .meta-dot {
      color: var(--color-text-dim);
    }

    .track-play {
      position: relative;
      min-width: 210px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 14px;
      overflow: hidden;
      padding: 13px 24px;
      border-color: rgba(242, 234, 216, 0.82);
      background:
        linear-gradient(90deg, rgba(232, 72, 82, 0.18), transparent 58%),
        rgba(22, 18, 31, 0.46);
      box-shadow:
        inset 0 0 0 1px rgba(242, 234, 216, 0.04),
        0 0 0 rgba(232, 72, 82, 0);
    }

    .track-play::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(110deg, transparent, rgba(232, 72, 82, 0.28), transparent);
      transform: translateX(-120%);
      animation: play-sweep 3s ease-in-out infinite;
    }

    .track-play:hover {
      border-color: var(--color-dancheong-red);
      background: var(--color-text-primary);
      box-shadow: 0 0 34px rgba(232, 72, 82, 0.24);
    }

    .track-play > span {
      position: relative;
      z-index: 1;
    }

    .play-disc {
      display: inline-grid;
      place-items: center;
      width: 24px;
      height: 24px;
      border-radius: 50%;
      color: var(--color-dancheong-red);
      background: rgba(232, 72, 82, 0.12);
      font-size: 10px;
      box-shadow: 0 0 16px rgba(232, 72, 82, 0.22);
    }

    .track-play:hover .play-disc {
      color: var(--color-bg);
      background: rgba(13, 10, 24, 0.1);
    }

    .play-label {
      letter-spacing: 0.24em;
    }

    .play-bars {
      display: inline-flex;
      align-items: center;
      gap: 3px;
      height: 18px;
    }

    .play-bars span {
      width: 2px;
      height: 10px;
      background: var(--color-dancheong-red);
      animation: play-bar 0.9s ease-in-out infinite;
    }

    .play-bars span:nth-child(2) {
      animation-delay: 0.15s;
    }

    .play-bars span:nth-child(3) {
      animation-delay: 0.3s;
    }

    .track-play:hover .play-bars span {
      background: var(--color-bg);
    }

    .wave-section {
      position: relative;
      padding: 12px 0 28px;
    }

    .wave-times {
      display: flex;
      justify-content: space-between;
      margin-top: 4px;
      color: var(--color-text-faded);
      font-size: 11px;
    }

    @keyframes stage-flow {
      0%, 42% {
        opacity: 0;
        transform: rotate(-18deg) translateX(-80%);
      }
      54% {
        opacity: 0.85;
      }
      100% {
        opacity: 0;
        transform: rotate(-18deg) translateX(170%);
      }
    }

    @keyframes card-sheen {
      0%, 58% {
        transform: translateX(-120%);
      }
      100% {
        transform: translateX(120%);
      }
    }

    @keyframes instrument-ring {
      from {
        opacity: 0.42;
        transform: scale(0.7);
      }
      to {
        opacity: 0;
        transform: scale(1.34);
      }
    }

    @keyframes instrument-float {
      0%, 100% {
        transform: translateY(0) rotate(-1deg);
      }
      50% {
        transform: translateY(-4px) rotate(1deg);
      }
    }

    @keyframes stamp-bounce {
      0%, 100% {
        transform: translateY(0);
      }
      50% {
        transform: translateY(-4px);
      }
    }

    @keyframes play-sweep {
      0%, 48% {
        transform: translateX(-120%);
      }
      100% {
        transform: translateX(120%);
      }
    }

    @keyframes play-bar {
      0%, 100% {
        transform: scaleY(0.48);
      }
      45% {
        transform: scaleY(1.25);
      }
    }

    @media (max-width: 720px) {
      .track-detail {
        padding: 0 20px 78px;
      }

      .track-back {
        margin: 18px 0 22px;
      }

      .track-grid {
        grid-template-columns: 1fr;
      }

      .track-stage {
        grid-template-columns: 1fr;
        gap: 28px;
        padding-top: 8px;
      }

      .artifact-card {
        min-height: 210px;
      }

      .instrument-field {
        min-height: 104px;
      }

      .track-title {
        font-size: 42px;
      }

      .track-play {
        width: 100%;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .stage-flow,
      .artifact-card::before,
      .instrument-ring,
      .instrument-symbol,
      .stamp-wrap,
      .track-play::before,
      .play-bars span {
        animation: none;
      }
    }
  </style>
</Layout>
