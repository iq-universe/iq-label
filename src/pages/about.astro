---
import Layout from '../layouts/Layout.astro';

const universe = [
  { label: 'IQ Lab Blog', url: 'https://iq-proof.github.io', desc: '딥다이브 발행 허브' },
  { label: 'IQ Dev Lab', url: 'https://iq-dev-lab.github.io', desc: '백엔드 deep-dive' },
  { label: 'IQ AI Lab', url: 'https://iq-ai-lab.github.io', desc: 'AI 이론 deep-dive' },
  { label: 'IQ Agent Lab', url: 'https://iq-agent-lab.github.io', desc: '에이전트 자동화 인프라' },
];
---

<Layout title="About — iq-label">
  <article style="max-width: 640px; margin: 0 auto; padding: 56px 24px;">
    <div class="tag" style="margin-bottom: 12px;">ABOUT / 소개</div>
    <h1
      class="serif"
      style="font-size: 38px; font-weight: 500; margin: 0 0 12px; line-height: 1.15;"
    >
      이큐 유니버스
    </h1>
    <p
      style="font-style: italic; font-size: 16px; color: var(--color-ink-soft); margin: 0 0 32px;"
    >
      iq-label은 IQ Universe의 발행처 중 하나입니다.
    </p>

    <div style="display: flex; flex-direction: column; border-top: 1px solid var(--color-border);">
      {
        universe.map((site) => (
          <a
            href={site.url}
            style="display: flex; justify-content: space-between; align-items: center; padding: 18px 0; border-bottom: 1px solid var(--color-border);"
          >
            <div>
              <div class="serif" style="font-size: 18px; font-weight: 500; line-height: 1.3;">
                {site.label}
              </div>
              <div class="mono" style="font-size: 11px; color: var(--color-ink-faded); margin-top: 4px;">
                {site.desc}
              </div>
            </div>
            <span class="mono" style="font-size: 14px; color: var(--color-ink-faded);">→</span>
          </a>
        ))
      }
    </div>
  </article>
</Layout>
