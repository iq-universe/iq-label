---
import QMark from './QMark.astro';
import DancheongLine from './DancheongLine.astro';

const navItems = [
  { href: '/genres', label: 'genres' },
  { href: '/manifesto', label: 'manifesto' },
  { href: '/about', label: 'about' },
];
---

<header class="site-header">
  <div class="site-header-inner">
    <a href="/" class="brand-mark">
      <span class="brand-symbol">
        <QMark size={52} />
      </span>
      <div class="brand-lockup">
        <span class="serif glow-cream brand-title">
          Label Q
        </span>
      </div>
    </a>
    <nav class="mono site-nav" aria-label="Primary navigation">
      {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
  </div>
  <DancheongLine />
</header>

<style>
  .site-header {
    max-width: 1080px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .site-header-inner {
    padding: 24px 32px 15px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
  }

  .brand-mark {
    display: flex;
    align-items: center;
    gap: 14px;
    min-width: max-content;
  }

  .brand-symbol {
    color: var(--color-text-primary);
    line-height: 0;
    transform-origin: center;
    transition: color 0.2s, transform 0.2s, filter 0.2s;
  }

  .brand-mark:hover .brand-symbol {
    color: var(--color-gold-bright);
    filter: drop-shadow(0 0 14px rgba(232, 72, 82, 0.22));
    transform: translateY(-1px) rotate(-3deg) scale(1.04);
  }

  .brand-lockup {
    display: flex;
    flex-direction: column;
  }

  .brand-title {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-size: 32px;
    font-weight: 500;
    line-height: 1.02;
    transition: color 0.2s, text-shadow 0.2s;
  }

  .brand-title::after {
    content: '';
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--color-dancheong-red);
    box-shadow: 0 0 12px rgba(232, 72, 82, 0.85);
    animation: brand-title-beat 1.55s ease-in-out infinite;
  }

  .brand-mark:hover .brand-title {
    color: var(--color-gold-bright);
    text-shadow:
      0 0 18px rgba(232, 72, 82, 0.28),
      0 0 28px rgba(212, 178, 122, 0.12);
  }

  .site-nav {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 24px;
    color: var(--color-text-secondary);
    font-size: 12px;
  }

  .site-nav a {
    position: relative;
    padding: 4px 0;
  }

  .site-nav a::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -3px;
    height: 1px;
    background: var(--color-dancheong-red);
    opacity: 0;
    transform: scaleX(0.35);
    transform-origin: center;
    transition: opacity 0.2s, transform 0.2s;
  }

  .site-nav a:hover::after {
    opacity: 0.8;
    transform: scaleX(1);
  }

  @media (max-width: 640px) {
    .site-header-inner {
      padding: 22px 20px 14px;
      gap: 16px;
    }

    .brand-mark {
      gap: 10px;
    }

    .brand-symbol :global(svg) {
      width: 34px;
      height: 34px;
    }

    .brand-title {
      gap: 7px;
      font-size: 23px;
    }

    .brand-title::after {
      width: 3px;
      height: 3px;
    }

    .site-nav {
      gap: 14px;
      font-size: 11px;
      letter-spacing: 0.06em;
    }
  }

  @media (max-width: 380px) {
    .site-header-inner {
      align-items: flex-start;
      flex-direction: column;
      gap: 14px;
    }

    .site-nav {
      width: 100%;
      justify-content: space-between;
    }
  }

  @keyframes brand-title-beat {
    0%, 100% {
      opacity: 0.52;
      transform: scale(0.75);
    }
    46% {
      opacity: 1;
      transform: scale(1.22);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .brand-title::after {
      animation: none;
      opacity: 0.75;
      transform: none;
    }
  }
</style>
