---
import QMark from './QMark.astro';
import DancheongLine from './DancheongLine.astro';

const navItems = [
  { href: '/genres', labelKo: '장르', labelEn: 'genres', match: ['/genres', '/genre', '/region'] },
  { href: '/manifesto', labelKo: '선언', labelEn: 'manifesto', match: ['/manifesto'] },
  { href: '/about', labelKo: '소개', labelEn: 'about', match: ['/about'] },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="site-header-inner">
    <a href="/" class="brand-mark">
      <span class="brand-symbol">
        <QMark size={52} />
      </span>
      <div class="brand-lockup">
        <span class="serif glow-cream brand-title">
          Label Q
        </span>
      </div>
    </a>
    <nav class="site-nav" aria-label="Primary navigation">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class={`nav-link ${item.match.some((path) => currentPath.startsWith(path)) ? 'is-active' : ''}`}
          >
            <span class="serif nav-ko">{item.labelKo}</span>
            <span class="mono nav-en">{item.labelEn}</span>
          </a>
        ))
      }
    </nav>
  </div>
  <DancheongLine />
</header>

<style>
  .site-header {
    max-width: 1080px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .site-header-inner {
    padding: 24px 32px 15px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
  }

  .brand-mark {
    display: flex;
    align-items: center;
    gap: 14px;
    min-width: max-content;
  }

  .brand-symbol {
    color: var(--color-text-primary);
    line-height: 0;
    transform-origin: center;
    transition: color 0.2s, transform 0.2s, filter 0.2s;
  }

  .brand-mark:hover .brand-symbol {
    color: var(--color-gold-bright);
    filter: drop-shadow(0 0 14px rgba(232, 72, 82, 0.22));
    transform: translateY(-1px) rotate(-3deg) scale(1.04);
  }

  .brand-lockup {
    display: flex;
    flex-direction: column;
  }

  .brand-title {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-size: 32px;
    font-weight: 500;
    line-height: 1.02;
    transition: color 0.2s, text-shadow 0.2s;
  }

  .brand-title::after {
    content: '';
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--color-dancheong-red);
    box-shadow: 0 0 12px rgba(232, 72, 82, 0.85);
    animation: brand-title-beat 1.55s ease-in-out infinite;
  }

  .brand-mark:hover .brand-title {
    color: var(--color-gold-bright);
    text-shadow:
      0 0 18px rgba(232, 72, 82, 0.28),
      0 0 28px rgba(212, 178, 122, 0.12);
  }

  .site-nav {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 10px;
  }

  .nav-link {
    position: relative;
    min-width: 96px;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2px;
    padding: 11px 15px 10px;
    overflow: hidden;
    color: var(--color-text-secondary);
    border: 1px solid rgba(184, 171, 148, 0.36);
    background:
      linear-gradient(180deg, rgba(242, 234, 216, 0.06), transparent 58%),
      rgba(22, 18, 31, 0.62);
    box-shadow:
      inset 0 1px 0 rgba(242, 234, 216, 0.04),
      0 12px 28px rgba(10, 6, 18, 0.16);
    transition: color 0.2s, border-color 0.2s, background 0.2s, box-shadow 0.2s, transform 0.2s;
  }

  .nav-link::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(110deg, transparent, rgba(232, 72, 82, 0.16), transparent);
    opacity: 0;
    transform: translateX(-120%);
    transition: opacity 0.2s;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    left: 12px;
    right: 12px;
    bottom: 5px;
    height: 2px;
    background: var(--color-dancheong-red);
    opacity: 0;
    transform: scaleX(0.4);
    transform-origin: center;
    transition: opacity 0.2s, transform 0.2s;
  }

  .nav-link:hover,
  .nav-link:focus-visible,
  .nav-link.is-active {
    color: var(--color-text-primary);
    border-color: rgba(232, 72, 82, 0.76);
    background:
      radial-gradient(circle at 50% 0%, rgba(232, 72, 82, 0.24), transparent 62%),
      rgba(22, 18, 31, 0.78);
    box-shadow:
      inset 0 1px 0 rgba(242, 234, 216, 0.08),
      0 0 24px rgba(232, 72, 82, 0.16);
    transform: translateY(-1px);
    outline: none;
  }

  .nav-link:hover::before,
  .nav-link:focus-visible::before {
    opacity: 1;
    animation: nav-sweep 1.8s ease-in-out infinite;
  }

  .nav-link:hover::after,
  .nav-link:focus-visible::after,
  .nav-link.is-active::after {
    opacity: 0.8;
    transform: scaleX(1);
  }

  .nav-ko {
    position: relative;
    z-index: 1;
    font-size: 16px;
    font-weight: 500;
    line-height: 1.12;
    letter-spacing: 0;
  }

  .nav-en {
    position: relative;
    z-index: 1;
    color: var(--color-text-faded);
    font-size: 8.5px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .nav-link:hover .nav-en,
  .nav-link:focus-visible .nav-en,
  .nav-link.is-active .nav-en {
    color: var(--color-stardust-gold);
  }

  @media (max-width: 640px) {
    .site-header-inner {
      flex-wrap: wrap;
      padding: 22px 20px 14px;
      gap: 16px;
    }

    .brand-mark {
      gap: 10px;
    }

    .brand-symbol :global(svg) {
      width: 34px;
      height: 34px;
    }

    .brand-title {
      gap: 7px;
      font-size: 23px;
    }

    .brand-title::after {
      width: 3px;
      height: 3px;
    }

    .site-nav {
      width: 100%;
      justify-content: space-between;
      gap: 8px;
    }

    .nav-link {
      flex: 1;
      min-width: 0;
      padding: 9px 10px 8px;
    }

    .nav-ko {
      font-size: 14px;
    }

    .nav-en {
      font-size: 7.5px;
    }
  }

  @media (max-width: 380px) {
    .site-header-inner {
      align-items: flex-start;
      flex-direction: column;
      gap: 14px;
    }

    .site-nav {
      width: 100%;
      justify-content: space-between;
    }
  }

  @keyframes brand-title-beat {
    0%, 100% {
      opacity: 0.52;
      transform: scale(0.75);
    }
    46% {
      opacity: 1;
      transform: scale(1.22);
    }
  }

  @keyframes nav-sweep {
    from {
      transform: translateX(-120%);
    }
    to {
      transform: translateX(120%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .brand-title::after {
      animation: none;
      opacity: 0.75;
      transform: none;
    }

    .nav-link:hover::before,
    .nav-link:focus-visible::before {
      animation: none;
    }
  }
</style>
