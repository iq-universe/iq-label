---
import DancheongLine from './DancheongLine.astro';

const navItems = [
  { href: '/genres', label: 'genres', ko: '장르' },
  { href: '/manifesto', label: 'manifesto', ko: '선언' },
  { href: '/about', label: 'about', ko: '소개' },
];
---

<header style="max-width: 760px; margin: 0 auto;">
  <div
    style="padding: 24px 24px 14px; display: flex; justify-content: space-between; align-items: baseline;"
  >
    <a href="/" style="display: flex; align-items: baseline; gap: 10px;">
      <span class="serif" style="font-size: 22px; font-weight: 500;">이큐 라벨</span>
      <span class="mono" style="font-size: 11px; color: var(--color-ink-faded);">iq-label</span>
    </a>
    <nav class="mono" style="display: flex; gap: 22px; font-size: 12px; color: var(--color-ink-soft);">
      {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
  </div>
  <DancheongLine />
</header>
