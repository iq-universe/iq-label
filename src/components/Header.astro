---
const navItems = [
  { href: '/genres', label: 'genres' },
  { href: '/manifesto', label: 'manifesto' },
  { href: '/about', label: 'about' },
];
---

<header
  style="padding: 18px 24px; border-bottom: 0.5px solid var(--color-border); display: flex; justify-content: space-between; align-items: center; max-width: 760px; margin: 0 auto;"
>
  <a href="/" style="font-family: var(--font-mono); font-size: 14px; font-weight: 500;">iq-label</a>
  <nav style="display: flex; gap: 24px; font-size: 13px; color: var(--color-text-secondary);">
    {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
  </nav>
</header>
