---
import QMark from './QMark.astro';
import DancheongLine from './DancheongLine.astro';

const navItems = [
  { href: '/genres', label: 'genres' },
  { href: '/manifesto', label: 'manifesto' },
  { href: '/about', label: 'about' },
];
---

<header style="max-width: 760px; margin: 0 auto; position: relative;">
  <div
    style="padding: 24px 24px 14px; display: flex; justify-content: space-between; align-items: center;"
  >
    <a href="/" style="display: flex; align-items: center; gap: 12px;">
      <span style="color: var(--color-text-primary);">
        <QMark size={28} />
      </span>
      <div style="display: flex; flex-direction: column; gap: 2px;">
        <span class="serif glow-cream" style="font-size: 22px; font-weight: 500; line-height: 1;">
          Label Q
        </span>
        <span class="mono" style="font-size: 9px; color: var(--color-text-faded); letter-spacing: 0.18em;">
          라벨 큐 · iq-label
        </span>
      </div>
    </a>
    <nav class="mono" style="display: flex; gap: 22px; font-size: 12px; color: var(--color-text-secondary);">
      {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
  </div>
  <DancheongLine />
</header>
