---
import type { Genre } from '../types';
import JanguIcon from './icons/JanguIcon.astro';
import BukIcon from './icons/BukIcon.astro';
import GayageumIcon from './icons/GayageumIcon.astro';
import HaegeumIcon from './icons/HaegeumIcon.astro';
import DansoIcon from './icons/DansoIcon.astro';
import GeomungoIcon from './icons/GeomungoIcon.astro';

interface Props {
  genres: Genre[];
  showHeading?: boolean;
}

const { genres, showHeading = true } = Astro.props;

const iconMap: Record<string, any> = {
  janggu: JanguIcon,
  buk: BukIcon,
  gayageum: GayageumIcon,
  haegeum: HaegeumIcon,
  danso: DansoIcon,
  geomungo: GeomungoIcon,
};
---

<section style="padding: 28px 24px 14px; max-width: 760px; margin: 0 auto;">
  {
    showHeading && (
      <div style="display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 18px; padding-top: 10px; border-top: 1px solid var(--color-border);">
        <div>
          <span class="serif" style="font-size: 18px; font-weight: 500;">
            장르 / Genres
          </span>
          <span class="mono" style="font-size: 11px; color: var(--color-ink-faded); margin-left: 12px;">
            {genres.length} categories
          </span>
        </div>
      </div>
    )
  }
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 8px;">
    {
      genres.map((g) => {
        const Icon = iconMap[g.instrument] || JanguIcon;
        const isActive = g.status === 'active';
        return isActive ? (
          <a
            href={`/genre/${g.slug}`}
            style="background: var(--color-paper-warm); border: 0.5px solid var(--color-border-strong); padding: 16px 14px; position: relative; display: block;"
          >
            <div style="margin-bottom: 10px; color: var(--color-ink);">
              <Icon size={28} />
            </div>
            <div class="serif" style="font-size: 16px; font-weight: 500; line-height: 1.2;">
              {g.instrument_label_ko}
            </div>
            <div class="mono" style="font-size: 11px; color: var(--color-ink-faded); margin-top: 2px;">
              {g.label} · {g.track_count}
            </div>
            <div
              style="position: absolute; top: 12px; right: 12px; width: 6px; height: 6px; background: var(--color-dancheong-red); border-radius: 50%;"
            />
          </a>
        ) : (
          <div
            style="background: var(--color-paper-warm); border: 0.5px solid var(--color-border); padding: 16px 14px; opacity: 0.55;"
          >
            <div style="margin-bottom: 10px; color: var(--color-ink);">
              <Icon size={28} />
            </div>
            <div class="serif" style="font-size: 16px; font-weight: 500; line-height: 1.2;">
              {g.instrument_label_ko}
            </div>
            <div class="mono" style="font-size: 11px; color: var(--color-ink-faded); margin-top: 2px;">
              {g.label} · soon
            </div>
          </div>
        );
      })
    }
  </div>
</section>
