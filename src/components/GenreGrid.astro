---
import type { Genre } from '../types';

interface Props {
  genres: Genre[];
}

const { genres } = Astro.props;
---

<section style="padding: 24px; max-width: 760px; margin: 0 auto;">
  <div class="tag" style="margin-bottom: 14px;">genres</div>
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 10px;">
    {
      genres.map((g) =>
        g.status === 'active' ? (
          <a
            href={`/genre/${g.slug}`}
            style="background: var(--color-bg-card); border: 0.5px solid var(--color-border-strong); border-radius: var(--radius-md); padding: 16px; display: block;"
          >
            <div class="mono" style="font-size: 13px; font-weight: 500;">
              {g.label}
            </div>
            <div style="font-size: 12px; color: var(--color-text-tertiary); margin-top: 4px;">
              {g.track_count} tracks
            </div>
          </a>
        ) : (
          <div
            style="background: var(--color-bg-card); border: 0.5px solid var(--color-border); border-radius: var(--radius-md); padding: 16px; opacity: 0.55;"
          >
            <div class="mono" style="font-size: 13px;">
              {g.label}
            </div>
            <div style="font-size: 12px; color: var(--color-text-tertiary); margin-top: 4px;">
              coming
            </div>
          </div>
        ),
      )
    }
  </div>
</section>
