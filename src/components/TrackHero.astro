---
import type { Track } from '../types';
import IQResonator from './IQResonator.astro';
import JanguIcon from './icons/JanguIcon.astro';
import BukIcon from './icons/BukIcon.astro';
import GayageumIcon from './icons/GayageumIcon.astro';
import HaegeumIcon from './icons/HaegeumIcon.astro';
import DansoIcon from './icons/DansoIcon.astro';
import GeomungoIcon from './icons/GeomungoIcon.astro';

interface Props {
  track: Track;
}

const { track } = Astro.props;
const trackJson = JSON.stringify(track);

const iconMap: Record<string, any> = {
  janggu: JanguIcon,
  buk: BukIcon,
  gayageum: GayageumIcon,
  haegeum: HaegeumIcon,
  danso: DansoIcon,
  geomungo: GeomungoIcon,
};

const InstrumentIcon = iconMap[track.fusion_instrument] || JanguIcon;
const instrumentLabel = track.fusion_with_label || track.fusion_with;
---

<section style="position: relative; padding: 64px 32px 56px; max-width: 1080px; margin: 0 auto;">
  <div style="position: absolute; top: 28px; right: 32px; pointer-events: none;">
    <div class="fan-wrap">
      <IQResonator size={380} />
    </div>
  </div>

  <div class="tag" style="margin-bottom: 28px;">
    第 {track.number} 號 — LATEST DROP / NO. {track.number}
  </div>

  <h1
    class="serif glow-cream"
    style="font-size: 64px; font-weight: 500; margin: 0 0 14px; line-height: 1.05; max-width: 600px;"
  >
    <a href={`/track/${track.id}`}>{track.title_ko}</a>
  </h1>

  <div
    style="font-style: italic; font-size: 17px; color: var(--color-text-secondary); margin-bottom: 32px; max-width: 400px;"
  >
    {track.title_en}
  </div>

  <div
    class="mono"
    style="display: flex; align-items: center; gap: 14px; font-size: 14px; color: var(--color-text-secondary); margin-bottom: 32px;"
  >
    <InstrumentIcon size={24} />
    <span class="serif" style="font-size: 15px; letter-spacing: 0; color: var(--color-text-primary);">
      {instrumentLabel}
    </span>
    <span class="fusion-op">⊗</span>
    <span>{track.genre}</span>
  </div>

  <button data-track={trackJson}>▶ PLAY · {track.duration_label}</button>
</section>

<style>
  @media (max-width: 820px) {
    .fan-wrap {
      transform: scale(0.7);
      transform-origin: top right;
      opacity: 0.7;
    }
  }
  @media (max-width: 540px) {
    .fan-wrap {
      transform: scale(0.5);
      opacity: 0.55;
    }
  }
</style>
