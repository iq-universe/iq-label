---
import type { Track } from '../types';
import IQResonator from './IQResonator.astro';
import JanguIcon from './icons/JanguIcon.astro';
import BukIcon from './icons/BukIcon.astro';
import GayageumIcon from './icons/GayageumIcon.astro';
import HaegeumIcon from './icons/HaegeumIcon.astro';
import DansoIcon from './icons/DansoIcon.astro';
import GeomungoIcon from './icons/GeomungoIcon.astro';

interface Props {
  track: Track;
}

const { track } = Astro.props;
const trackJson = JSON.stringify(track);

const iconMap: Record<string, any> = {
  janggu: JanguIcon,
  buk: BukIcon,
  gayageum: GayageumIcon,
  haegeum: HaegeumIcon,
  danso: DansoIcon,
  geomungo: GeomungoIcon,
};

const InstrumentIcon = iconMap[track.fusion_instrument] || JanguIcon;
const instrumentLabel = track.fusion_with_label || track.fusion_with;
---

<section class="track-hero">
  <div class="hero-resonator" aria-hidden="true">
    <div class="resonator-wrap">
      <IQResonator size={540} />
    </div>
  </div>

  <div class="hero-content">
    <h1 class="serif glow-cream hero-title">
      <a href={`/track/${track.id}`}>{track.title_ko}</a>
    </h1>

    <div class="hero-subtitle">
      {track.title_en}
    </div>

    <div class="mono hero-meta">
      <InstrumentIcon size={24} />
      <span class="serif instrument-label">
        {instrumentLabel}
      </span>
      <span class="fusion-op">⊗</span>
      <span>{track.genre}</span>
    </div>

    <button class="hero-play" data-track={trackJson}>
      <span class="play-icon">▶</span>
      <span>PLAY</span>
      <span class="play-duration">{track.duration_label}</span>
    </button>
  </div>
</section>

<style>
  .track-hero {
    position: relative;
    max-width: 1080px;
    min-height: 330px;
    margin: 0 auto;
    padding: 64px 32px 56px;
    overflow: hidden;
    isolation: isolate;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 620px;
    padding-top: 58px;
  }

  .hero-resonator {
    position: absolute;
    z-index: 0;
    top: 4px;
    left: clamp(180px, 21vw, 250px);
    width: clamp(500px, 50vw, 590px);
    pointer-events: none;
    opacity: 0.86;
  }

  .resonator-wrap,
  .resonator-wrap :global(svg) {
    width: 100%;
    height: auto;
  }

  .hero-title {
    max-width: 600px;
    margin: 0 0 14px;
    font-size: clamp(48px, 6vw, 64px);
    font-weight: 500;
    line-height: 1.05;
  }

  .hero-subtitle {
    max-width: 400px;
    margin-bottom: 32px;
    color: var(--color-text-secondary);
    font-size: 17px;
    font-style: italic;
  }

  .hero-meta {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 32px;
    color: var(--color-text-secondary);
    font-size: 14px;
  }

  .instrument-label {
    color: var(--color-text-primary);
    font-size: 15px;
    letter-spacing: 0;
  }

  .hero-play {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    overflow: hidden;
    min-width: 176px;
    border-color: rgba(242, 234, 216, 0.78);
    background:
      linear-gradient(90deg, rgba(232, 72, 82, 0.14), transparent 55%),
      rgba(22, 18, 31, 0.42);
    box-shadow:
      inset 0 0 0 1px rgba(242, 234, 216, 0.05),
      0 0 0 rgba(232, 72, 82, 0);
  }

  .hero-play::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(110deg, transparent, rgba(242, 234, 216, 0.22), transparent);
    transform: translateX(-120%);
    animation: hero-play-sweep 3.6s ease-in-out infinite;
  }

  .hero-play:hover {
    border-color: var(--color-dancheong-red);
    background: var(--color-text-primary);
    box-shadow: 0 0 32px rgba(232, 72, 82, 0.22);
  }

  .hero-play > span {
    position: relative;
    z-index: 1;
  }

  .play-icon {
    color: var(--color-dancheong-red);
    font-size: 11px;
  }

  .hero-play:hover .play-icon {
    color: var(--color-bg);
  }

  .play-duration {
    color: var(--color-text-faded);
  }

  .hero-play:hover .play-duration {
    color: rgba(13, 10, 24, 0.72);
  }

  @keyframes hero-play-sweep {
    0%, 54% {
      transform: translateX(-120%);
    }
    100% {
      transform: translateX(120%);
    }
  }

  @media (max-width: 820px) {
    .track-hero {
      min-height: 310px;
      padding: 56px 28px 48px;
    }

    .hero-content {
      padding-top: 48px;
    }

    .hero-resonator {
      top: 18px;
      left: 31%;
      width: 470px;
      opacity: 0.5;
    }
  }

  @media (max-width: 540px) {
    .track-hero {
      min-height: 310px;
      padding: 50px 24px 44px;
    }

    .hero-content {
      padding-top: 42px;
    }

    .hero-resonator {
      top: 28px;
      left: 13%;
      width: 380px;
      opacity: 0.32;
    }

    .hero-title {
      font-size: 42px;
    }

    .hero-meta {
      align-items: flex-start;
      flex-wrap: wrap;
      gap: 10px 12px;
    }
  }
</style>
