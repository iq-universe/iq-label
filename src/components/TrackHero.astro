---
import type { Track } from '../types';
import IQResonator from './IQResonator.astro';
import JanguIcon from './icons/JanguIcon.astro';
import BukIcon from './icons/BukIcon.astro';
import GayageumIcon from './icons/GayageumIcon.astro';
import HaegeumIcon from './icons/HaegeumIcon.astro';
import DansoIcon from './icons/DansoIcon.astro';
import GeomungoIcon from './icons/GeomungoIcon.astro';

interface Props {
  track: Track;
}

const { track } = Astro.props;
const trackJson = JSON.stringify(track);

const iconMap: Record<string, any> = {
  janggu: JanguIcon,
  buk: BukIcon,
  gayageum: GayageumIcon,
  haegeum: HaegeumIcon,
  danso: DansoIcon,
  geomungo: GeomungoIcon,
};

const InstrumentIcon = iconMap[track.fusion_instrument] || JanguIcon;
const instrumentLabel = track.fusion_with_label || track.fusion_with;
---

<section class="track-hero">
  <canvas class="hero-soundfield" data-track-id={track.id} aria-hidden="true"></canvas>
  <div class="hero-core" aria-hidden="true"></div>

  <div class="hero-resonator" aria-hidden="true">
    <div class="resonator-wrap">
      <IQResonator size={540} />
    </div>
  </div>

  <div class="hero-content">
    <h1 class="serif glow-cream hero-title">
      <a href={`/track/${track.id}`}>{track.title_ko}</a>
    </h1>

    <div class="hero-subtitle">
      {track.title_en}
    </div>

    <div class="mono hero-meta">
      <InstrumentIcon size={24} />
      <span class="serif instrument-label">
        {instrumentLabel}
      </span>
      <span class="fusion-op">⊗</span>
      <span>{track.genre}</span>
    </div>

    <button class="hero-play" data-track={trackJson}>
      <span class="play-icon">▶</span>
      <span>PLAY</span>
      <span class="play-duration">{track.duration_label}</span>
    </button>
  </div>
</section>

<style>
  .track-hero {
    position: relative;
    max-width: 1080px;
    min-height: min(72vh, 680px);
    margin: 0 auto;
    padding: clamp(74px, 8vw, 112px) 32px clamp(80px, 9vw, 118px);
    overflow: hidden;
    isolation: isolate;
  }

  .hero-soundfield {
    position: absolute;
    inset: 0;
    z-index: -3;
    width: 100%;
    height: 100%;
    opacity: 0.82;
  }

  .hero-core {
    position: absolute;
    z-index: -2;
    top: 50%;
    left: 58%;
    width: min(680px, 62vw);
    aspect-ratio: 1;
    border-radius: 50%;
    pointer-events: none;
    background:
      radial-gradient(circle at center, rgba(242, 234, 216, 0.13), rgba(232, 72, 82, 0.12) 14%, rgba(232, 72, 82, 0.045) 34%, transparent 68%);
    filter: blur(3px);
    transform: translate(-50%, -50%);
    animation: hero-core-breathe 7s ease-in-out infinite;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 620px;
    padding-top: 18px;
  }

  .hero-resonator {
    position: absolute;
    z-index: 1;
    top: clamp(74px, 8vw, 104px);
    left: clamp(260px, 36vw, 430px);
    width: clamp(500px, 45vw, 620px);
    pointer-events: none;
    opacity: 0.9;
  }

  .resonator-wrap,
  .resonator-wrap :global(svg) {
    width: 100%;
    height: auto;
  }

  .hero-title {
    max-width: 600px;
    margin: 0 0 14px;
    font-size: clamp(48px, 6vw, 64px);
    font-weight: 500;
    line-height: 1.05;
  }

  .hero-subtitle {
    max-width: 400px;
    margin-bottom: 32px;
    color: var(--color-text-secondary);
    font-size: 17px;
    font-style: italic;
  }

  @keyframes hero-core-breathe {
    0%, 100% {
      opacity: 0.62;
      transform: translate(-50%, -50%) scale(0.96);
    }
    50% {
      opacity: 1;
      transform: translate(-50%, -50%) scale(1.08);
    }
  }

  .hero-meta {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 32px;
    color: var(--color-text-secondary);
    font-size: 14px;
  }

  .instrument-label {
    color: var(--color-text-primary);
    font-size: 15px;
    letter-spacing: 0;
  }

  .hero-play {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    overflow: hidden;
    min-width: 176px;
    border-color: rgba(242, 234, 216, 0.78);
    background:
      linear-gradient(90deg, rgba(232, 72, 82, 0.14), transparent 55%),
      rgba(22, 18, 31, 0.42);
    box-shadow:
      inset 0 0 0 1px rgba(242, 234, 216, 0.05),
      0 0 0 rgba(232, 72, 82, 0);
  }

  .hero-play::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(110deg, transparent, rgba(242, 234, 216, 0.22), transparent);
    transform: translateX(-120%);
    animation: hero-play-sweep 3.6s ease-in-out infinite;
  }

  .hero-play:hover {
    border-color: var(--color-dancheong-red);
    background: var(--color-text-primary);
    box-shadow: 0 0 32px rgba(232, 72, 82, 0.22);
  }

  .hero-play > span {
    position: relative;
    z-index: 1;
  }

  .play-icon {
    color: var(--color-dancheong-red);
    font-size: 11px;
  }

  .hero-play:hover .play-icon {
    color: var(--color-bg);
  }

  .play-duration {
    color: var(--color-text-faded);
  }

  .hero-play:hover .play-duration {
    color: rgba(13, 10, 24, 0.72);
  }

  @keyframes hero-play-sweep {
    0%, 54% {
      transform: translateX(-120%);
    }
    100% {
      transform: translateX(120%);
    }
  }

  @media (max-width: 820px) {
    .track-hero {
      min-height: 560px;
      padding: 68px 28px 58px;
    }

    .hero-content {
      padding-top: 26px;
    }

    .hero-resonator {
      top: 112px;
      left: 34%;
      width: 470px;
      opacity: 0.42;
    }
  }

  @media (max-width: 540px) {
    .track-hero {
      min-height: 540px;
      padding: 62px 24px 54px;
    }

    .hero-content {
      padding-top: 46px;
    }

    .hero-resonator {
      top: 136px;
      left: 14%;
      width: 380px;
      opacity: 0.28;
    }

    .hero-title {
      font-size: 42px;
    }

    .hero-meta {
      align-items: flex-start;
      flex-wrap: wrap;
      gap: 10px 12px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-core,
    .hero-play::before {
      animation: none;
    }

    .hero-soundfield {
      display: none;
    }
  }
</style>

<script>
  function initHeroSoundfields() {
    const canvases = document.querySelectorAll('.hero-soundfield');
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    canvases.forEach((canvas) => {
      if (canvas.dataset.ready === 'true') return;
      canvas.dataset.ready = 'true';

      const ctx = canvas.getContext('2d');
      if (!ctx) return;

      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      let width = 0;
      let height = 0;
      let mouseX = 0;
      let mouseY = 0;
      let targetX = 0;
      let targetY = 0;
      let particles = [];

      function random(seed) {
        const x = Math.sin(seed * 999) * 10000;
        return x - Math.floor(x);
      }

      function resize() {
        const rect = canvas.getBoundingClientRect();
        width = rect.width;
        height = rect.height;
        canvas.width = Math.max(1, Math.floor(width * dpr));
        canvas.height = Math.max(1, Math.floor(height * dpr));
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

        const count = Math.min(130, Math.max(56, Math.floor((width * height) / 7800)));
        particles = Array.from({ length: count }, (_, index) => {
          const depth = 0.25 + random(index + 3) * 0.9;
          return {
            x: random(index + 11) * width,
            y: random(index + 29) * height,
            depth,
            radius: 0.45 + depth * 1.25,
            phase: random(index + 47) * Math.PI * 2,
            speed: 0.006 + random(index + 71) * 0.016,
            drift: (random(index + 93) - 0.5) * 0.08,
            warm: random(index + 111) > 0.55,
          };
        });
      }

      function draw() {
        mouseX += (targetX - mouseX) * 0.055;
        mouseY += (targetY - mouseY) * 0.055;
        ctx.clearRect(0, 0, width, height);
        ctx.globalCompositeOperation = 'lighter';

        const cx = width / 2;
        const cy = height / 2;
        const moveX = ((mouseX || cx) - cx) / Math.max(cx, 1);
        const moveY = ((mouseY || cy) - cy) / Math.max(cy, 1);

        particles.forEach((particle) => {
          particle.phase += particle.speed;
          particle.x += particle.drift;
          if (particle.x < -8) particle.x = width + 8;
          if (particle.x > width + 8) particle.x = -8;

          const px = particle.x + moveX * particle.depth * 18;
          const py = particle.y + moveY * particle.depth * 14 + Math.sin(particle.phase) * particle.depth * 5;
          const pulse = (Math.sin(particle.phase * 1.6) + 1) / 2;
          const alpha = 0.28 + pulse * 0.55;
          const color = particle.warm ? '232,72,82' : '242,234,216';

          const gradient = ctx.createRadialGradient(px, py, 0, px, py, particle.radius * 5.8);
          gradient.addColorStop(0, `rgba(${color},${alpha})`);
          gradient.addColorStop(0.45, `rgba(${color},${alpha * 0.18})`);
          gradient.addColorStop(1, `rgba(${color},0)`);

          ctx.fillStyle = gradient;
          ctx.beginPath();
          ctx.arc(px, py, particle.radius * 5.8, 0, Math.PI * 2);
          ctx.fill();
        });

        requestAnimationFrame(draw);
      }

      canvas.closest('.track-hero')?.addEventListener('mousemove', (event) => {
        const rect = canvas.getBoundingClientRect();
        targetX = event.clientX - rect.left;
        targetY = event.clientY - rect.top;
      });

      resize();
      window.addEventListener('resize', resize);
      draw();
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHeroSoundfields);
  } else {
    initHeroSoundfields();
  }
</script>
