---
interface Props {
  trackId: string;
  bars?: number;
}

const { trackId, bars = 50 } = Astro.props;

function seededRandom(seed: string, i: number): number {
  let h = 0;
  const s = seed + ':' + i;
  for (let j = 0; j < s.length; j++) {
    h = (h * 31 + s.charCodeAt(j)) | 0;
  }
  return Math.abs(Math.sin(h)) % 1;
}

const heights = Array.from({ length: bars }, (_, i) => {
  const r = seededRandom(trackId, i);
  return Math.round(8 + r * 36);
});
const playedRatio = 0.45;
---

<div class="waveform" aria-hidden="true">
  <div class="waveflow"></div>
  <svg class="waveform-svg" width="100%" height="78" viewBox={`0 0 ${bars * 12} 78`} preserveAspectRatio="none">
    {
      heights.map((h, i) => {
        const isPlayed = i / bars < playedRatio;
        return (
          <rect
            class={`wave-bar ${isPlayed ? 'wave-bar-hot' : 'wave-bar-cool'}`}
            x={i * 12}
            y={(78 - h) / 2}
            width="6"
            height={h}
            rx="1"
            style={`--delay: ${(i % 14) * 0.055}s;`}
          />
        );
      })
    }
  </svg>
  <div class="wave-playhead"></div>
</div>

<style>
  .waveform {
    position: relative;
    overflow: hidden;
    min-height: 86px;
    padding: 4px 0;
  }

  .waveflow {
    position: absolute;
    inset: 8px 0;
    background:
      linear-gradient(90deg, transparent, rgba(232, 72, 82, 0.14), transparent),
      radial-gradient(circle at 22% 50%, rgba(232, 72, 82, 0.18), transparent 18%);
    opacity: 0.82;
    transform: translateX(-34%);
    animation: waveflow 6.4s cubic-bezier(0.18, 0.72, 0.22, 1) infinite;
  }

  .waveform-svg {
    position: relative;
    z-index: 1;
    display: block;
    filter: drop-shadow(0 8px 18px rgba(232, 72, 82, 0.09));
  }

  .wave-bar {
    transform-box: fill-box;
    transform-origin: center;
    animation: wave-breathe 1.3s ease-in-out infinite;
    animation-delay: var(--delay);
  }

  .wave-bar-hot {
    fill: var(--color-dancheong-red);
    opacity: 0.95;
    filter: drop-shadow(0 0 8px rgba(232, 72, 82, 0.55));
  }

  .wave-bar-cool {
    fill: var(--color-text-secondary);
    opacity: 0.32;
  }

  .wave-playhead {
    position: absolute;
    z-index: 2;
    top: 11px;
    bottom: 11px;
    left: 45%;
    width: 1px;
    background: linear-gradient(180deg, transparent, rgba(242, 234, 216, 0.86), transparent);
    box-shadow: 0 0 18px rgba(232, 72, 82, 0.45);
    opacity: 0.72;
    animation: playhead-pulse 1.55s ease-in-out infinite;
  }

  @keyframes waveflow {
    0% {
      transform: translateX(-36%);
      opacity: 0.36;
    }
    45% {
      opacity: 0.95;
    }
    100% {
      transform: translateX(42%);
      opacity: 0.2;
    }
  }

  @keyframes wave-breathe {
    0%, 100% {
      transform: scaleY(0.78);
    }
    46% {
      transform: scaleY(1.14);
    }
  }

  @keyframes playhead-pulse {
    0%, 100% {
      opacity: 0.34;
      transform: scaleY(0.72);
    }
    50% {
      opacity: 0.9;
      transform: scaleY(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .waveflow,
    .wave-bar,
    .wave-playhead {
      animation: none;
    }
  }
</style>
