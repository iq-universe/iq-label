---
interface Props {
  notes: string;
}

const { notes } = Astro.props;
---

<div class="vibe-notes">
  <div class="vibe-signal" aria-hidden="true"></div>
  <div class="tag vibe-tag">VIBE NOTES · 큐레이션 메모</div>
  <p class="serif vibe-copy">
    {notes}
  </p>
  <div class="vibe-cue" aria-hidden="true"></div>
</div>

<style>
  .vibe-notes {
    position: relative;
    overflow: hidden;
    padding: 28px 32px 30px;
    border-top: 0.5px solid var(--color-border);
    border-bottom: 0.5px solid rgba(42, 36, 56, 0.7);
    background:
      linear-gradient(90deg, rgba(232, 72, 82, 0.08), transparent 28%),
      rgba(22, 18, 31, 0.46);
    backdrop-filter: blur(5px);
  }

  .vibe-signal {
    position: absolute;
    inset: 0 auto 0 0;
    width: 3px;
    background: var(--color-dancheong-red);
    box-shadow: 0 0 22px rgba(232, 72, 82, 0.38);
    opacity: 0.82;
  }

  .vibe-tag {
    margin-bottom: 14px;
  }

  .vibe-copy {
    position: relative;
    z-index: 1;
    margin: 0;
    color: var(--color-text-primary);
    font-size: clamp(18px, 2.2vw, 24px);
    font-weight: 400;
    line-height: 1.7;
  }

  .vibe-cue {
    width: 28px;
    height: 2px;
    margin-top: 22px;
    background: var(--color-dancheong-red);
    box-shadow: 0 0 8px rgba(232, 72, 82, 0.64);
    animation: vibe-cue 1.6s ease-in-out infinite;
  }

  @keyframes vibe-cue {
    0%, 100% {
      width: 18px;
      opacity: 0.62;
    }
    50% {
      width: 42px;
      opacity: 1;
    }
  }

  @media (max-width: 540px) {
    .vibe-notes {
      padding: 24px 20px 26px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .vibe-cue {
      animation: none;
    }
  }
</style>
