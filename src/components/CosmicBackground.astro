---
const stars = Array.from({ length: 140 }, (_, i) => {
  const seedA = ((i * 9301 + 49297) % 233280) / 233280;
  const seedB = ((i * 1664 + 1013) % 233280) / 233280;
  const seedC = ((i * 7919 + 3001) % 233280) / 233280;
  const seedD = ((i * 4271 + 1597) % 233280) / 233280;
  return {
    x: seedA * 100,
    y: seedB * 100,
    r: seedC * 1.1 + 0.3,
    opacity: seedD * 0.6 + 0.2,
    twinkle: i % 7 === 0,
    twinkleDelay: (i % 11) * 0.4,
  };
});

const dustParticles = Array.from({ length: 40 }, (_, i) => {
  const seedA = ((i * 1597 + 911) % 233280) / 233280;
  const seedB = ((i * 4421 + 13) % 233280) / 233280;
  return {
    x: seedA * 100,
    y: seedB * 100,
    r: ((i * 3) % 10) / 8 + 0.4,
  };
});

const supernovaRipples = [{ delay: 0 }, { delay: 3.7 }, { delay: 7.4 }];
const purpleRipples = [{ delay: 1.5 }, { delay: 8 }];
---

<div class="cosmic-bg" aria-hidden="true">
  <svg
    width="100%"
    height="100%"
    viewBox="0 0 100 100"
    preserveAspectRatio="xMidYMid slice"
    style="position: absolute; inset: 0;"
  >
    <defs>
      <radialGradient id="supernova" cx="78%" cy="20%" r="20%">
        <stop offset="0%" stop-color="rgba(232, 72, 82, 0.28)" />
        <stop offset="40%" stop-color="rgba(232, 72, 82, 0.10)" />
        <stop offset="100%" stop-color="rgba(232, 72, 82, 0)" />
      </radialGradient>
      <radialGradient id="supernova-core" cx="78%" cy="20%" r="3%">
        <stop offset="0%" stop-color="rgba(255, 220, 200, 0.6)" />
        <stop offset="100%" stop-color="rgba(232, 72, 82, 0)" />
      </radialGradient>
      <radialGradient id="distant-glow" cx="20%" cy="68%" r="22%">
        <stop offset="0%" stop-color="rgba(139, 111, 191, 0.12)" />
        <stop offset="100%" stop-color="rgba(139, 111, 191, 0)" />
      </radialGradient>
    </defs>

    <rect width="100" height="100" fill="url(#supernova)" />
    <rect width="100" height="100" fill="url(#distant-glow)" />
    <rect width="100" height="100" fill="url(#supernova-core)" />

    <g aria-hidden="true">
      {
        supernovaRipples.map((ring) => (
          <circle
            cx="78"
            cy="18"
            r="0.3"
            fill="none"
            stroke="#E84852"
            stroke-width="0.15"
            opacity="0"
          >
            <animate
              attributeName="r"
              from="0.3"
              to="42"
              dur="11s"
              repeatCount="indefinite"
              begin={`${ring.delay}s`}
            />
            <animate
              attributeName="opacity"
              from="0.45"
              to="0"
              dur="11s"
              repeatCount="indefinite"
              begin={`${ring.delay}s`}
            />
            <animate
              attributeName="stroke-width"
              from="0.3"
              to="0.04"
              dur="11s"
              repeatCount="indefinite"
              begin={`${ring.delay}s`}
            />
          </circle>
        ))
      }

      {
        purpleRipples.map((ring) => (
          <circle
            cx="20"
            cy="70"
            r="0.3"
            fill="none"
            stroke="#8B6FBF"
            stroke-width="0.12"
            opacity="0"
          >
            <animate
              attributeName="r"
              from="0.3"
              to="34"
              dur="13s"
              repeatCount="indefinite"
              begin={`${ring.delay}s`}
            />
            <animate
              attributeName="opacity"
              from="0.32"
              to="0"
              dur="13s"
              repeatCount="indefinite"
              begin={`${ring.delay}s`}
            />
          </circle>
        ))
      }

      <circle cx="78" cy="18" r="0.4" fill="rgba(255, 220, 200, 0.7)">
        <animate
          attributeName="r"
          values="0.3;0.55;0.3"
          dur="4s"
          repeatCount="indefinite"
        />
        <animate
          attributeName="opacity"
          values="0.5;0.85;0.5"
          dur="4s"
          repeatCount="indefinite"
        />
      </circle>
    </g>

    {
      dustParticles.map((p) => (
        <circle cx={p.x} cy={p.y} r={p.r * 0.04} fill="rgba(212, 178, 122, 0.4)" />
      ))
    }

    {
      stars.map((s) => (
        <circle
          cx={s.x}
          cy={s.y}
          r={s.r * 0.05}
          fill="rgb(242, 234, 216)"
          opacity={s.opacity}
          style={s.twinkle ? `animation: twinkle 4s ease-in-out infinite; animation-delay: ${s.twinkleDelay}s;` : ''}
        />
      ))
    }
  </svg>
</div>
