---
interface Props {
  size?: number;
  color?: string;
  strokeWidth?: number;
}

const { size = 32, color = 'currentColor', strokeWidth = 1.3 } = Astro.props;
---

<svg
  width={size}
  height={size * 0.55}
  viewBox="0 0 36 20"
  fill="none"
  stroke={color}
  stroke-width={strokeWidth}
  stroke-linecap="round"
  aria-label="거문고"
  role="img"
>
  <path d="M 2 8 Q 4 4 8 4 L 28 4 Q 32 4 34 8 L 34 14 Q 32 18 28 18 L 8 18 Q 4 18 2 14 Z" />
  <line x1="6" y1="8" x2="30" y2="8" stroke-width="0.5" />
  <line x1="6" y1="10" x2="30" y2="10" stroke-width="0.5" />
  <line x1="6" y1="12" x2="30" y2="12" stroke-width="0.5" />
  <line x1="6" y1="14" x2="30" y2="14" stroke-width="0.5" />
  <circle cx="14" cy="11" r="0.8" fill={color} />
  <circle cx="22" cy="11" r="0.8" fill={color} />
</svg>
