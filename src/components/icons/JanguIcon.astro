---
interface Props {
  size?: number;
  color?: string;
  strokeWidth?: number;
}

const { size = 32, color = 'currentColor', strokeWidth = 1.3 } = Astro.props;
---

<svg
  width={size}
  height={size * 0.6}
  viewBox="0 0 36 22"
  fill="none"
  stroke={color}
  stroke-width={strokeWidth}
  stroke-linecap="round"
  aria-label="장구"
  role="img"
>
  <ellipse cx="4" cy="11" rx="2.5" ry="9" />
  <line x1="4" y1="2" x2="14" y2="8" />
  <line x1="4" y1="20" x2="14" y2="14" />
  <ellipse cx="18" cy="11" rx="1.5" ry="3.5" />
  <line x1="22" y1="8" x2="32" y2="2" />
  <line x1="22" y1="14" x2="32" y2="20" />
  <ellipse cx="32" cy="11" rx="2.5" ry="9" />
</svg>
