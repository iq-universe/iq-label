---
interface Props {
  size?: number;
  color?: string;
  strokeWidth?: number;
}

const { size = 32, color = 'currentColor', strokeWidth = 1.3 } = Astro.props;
---

<svg
  width={size}
  height={size * 0.85}
  viewBox="0 0 30 26"
  fill="none"
  stroke={color}
  stroke-width={strokeWidth}
  stroke-linecap="round"
  aria-label="북"
  role="img"
>
  <ellipse cx="15" cy="13" rx="13" ry="11" />
  <ellipse cx="15" cy="13" rx="9" ry="9" />
  <line x1="2" y1="13" x2="6" y2="13" />
  <line x1="24" y1="13" x2="28" y2="13" />
  <circle cx="15" cy="13" r="1.2" fill={color} />
</svg>
