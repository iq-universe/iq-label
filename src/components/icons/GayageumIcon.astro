---
interface Props {
  size?: number;
  color?: string;
  strokeWidth?: number;
}

const { size = 32, color = 'currentColor', strokeWidth = 1.3 } = Astro.props;
---

<svg
  width={size}
  height={size * 0.65}
  viewBox="0 0 32 22"
  fill="none"
  stroke={color}
  stroke-width={strokeWidth}
  stroke-linecap="round"
  aria-label="가야금"
  role="img"
>
  <rect x="2" y="6" width="28" height="9" rx="1" />
  <line x1="6" y1="9" x2="26" y2="9" stroke-width="0.5" />
  <line x1="6" y1="11" x2="26" y2="11" stroke-width="0.5" />
  <line x1="6" y1="13" x2="26" y2="13" stroke-width="0.5" />
  <line x1="5" y1="3" x2="5" y2="6" stroke-width="0.7" />
  <line x1="9" y1="3" x2="9" y2="6" stroke-width="0.7" />
  <line x1="13" y1="3" x2="13" y2="6" stroke-width="0.7" />
  <line x1="17" y1="3" x2="17" y2="6" stroke-width="0.7" />
  <line x1="21" y1="3" x2="21" y2="6" stroke-width="0.7" />
  <line x1="25" y1="3" x2="25" y2="6" stroke-width="0.7" />
</svg>
