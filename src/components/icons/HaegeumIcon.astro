---
interface Props {
  size?: number;
  color?: string;
  strokeWidth?: number;
}

const { size = 32, color = 'currentColor', strokeWidth = 1.3 } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 28 28"
  fill="none"
  stroke={color}
  stroke-width={strokeWidth}
  stroke-linecap="round"
  aria-label="해금"
  role="img"
>
  <circle cx="14" cy="20" r="5" />
  <line x1="14" y1="3" x2="14" y2="15" />
  <line x1="11" y1="6" x2="17" y2="6" stroke-width="0.7" />
  <line x1="11" y1="9" x2="17" y2="9" stroke-width="0.7" />
  <line x1="2" y1="14" x2="26" y2="22" stroke-width="0.7" />
</svg>
