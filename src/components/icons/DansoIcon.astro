---
interface Props {
  size?: number;
  color?: string;
  strokeWidth?: number;
}

const { size = 32, color = 'currentColor', strokeWidth = 1.3 } = Astro.props;
---

<svg
  width={size * 0.4}
  height={size}
  viewBox="0 0 12 28"
  fill="none"
  stroke={color}
  stroke-width={strokeWidth}
  stroke-linecap="round"
  aria-label="단소"
  role="img"
>
  <rect x="3" y="2" width="6" height="24" rx="0.5" />
  <line x1="3" y1="7" x2="9" y2="7" stroke-width="0.6" />
  <circle cx="6" cy="11" r="0.8" fill={color} />
  <circle cx="6" cy="15" r="0.8" fill={color} />
  <circle cx="6" cy="19" r="0.8" fill={color} />
  <circle cx="6" cy="23" r="0.8" fill={color} />
</svg>
