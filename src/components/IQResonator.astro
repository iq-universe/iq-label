---
/**
 * IQ Resonator
 *
 * Brand-anchored hero for Label Q.
 *
 * Concept: The operator IQ (I Question) is the resonance source.
 * - I slides diagonally into position
 * - Q is drawn (stroke-dashoffset) in the middle while I moves
 * - 6 horizontal "strings" fade in (guitar-like fretboard)
 * - Red pulse appears at center of Q (the resonance point)
 * - Sound waves emanate continuously from Q outward
 *
 * Total intro: ~1.7s. After that, continuous resonance loop.
 */

interface Props {
  size?: number;
}

const { size = 380 } = Astro.props;
---

<svg
  width={size}
  height={size * 0.65}
  viewBox="0 0 400 260"
  fill="none"
  aria-label="IQ Resonator — 진동의 source"
  role="img"
  style="filter: drop-shadow(0 0 24px rgba(232, 72, 82, 0.08));"
>
  <!-- Sparse decorative stars in surrounding space -->
  <g fill="#F2EAD8" opacity="0.3">
    <circle cx="50" cy="35" r="0.8" />
    <circle cx="370" cy="50" r="0.7" />
    <circle cx="385" cy="220" r="0.8" />
    <circle cx="25" cy="195" r="0.7" />
    <circle cx="155" cy="28" r="0.6" />
    <circle cx="285" cy="35" r="0.5" />
    <circle cx="75" cy="225" r="0.6" />
    <circle cx="340" cy="240" r="0.6" />
    <circle cx="15" cy="105" r="0.5" />
    <circle cx="388" cy="155" r="0.5" />
  </g>

  <!-- ============================================ -->
  <!-- Sound waves: continuous, emanate from Q -->
  <!-- ============================================ -->
  <g>
    <circle cx="230" cy="130" r="20" fill="none" stroke="#E84852" stroke-width="0.7" opacity="0">
      <animate
        attributeName="r"
        values="20;180"
        dur="4.5s"
        begin="1.7s"
        repeatCount="indefinite"
      />
      <animate
        attributeName="opacity"
        values="0.7;0"
        dur="4.5s"
        begin="1.7s"
        repeatCount="indefinite"
      />
    </circle>
    <circle cx="230" cy="130" r="20" fill="none" stroke="#E84852" stroke-width="0.6" opacity="0">
      <animate
        attributeName="r"
        values="20;180"
        dur="4.5s"
        begin="3.2s"
        repeatCount="indefinite"
      />
      <animate
        attributeName="opacity"
        values="0.7;0"
        dur="4.5s"
        begin="3.2s"
        repeatCount="indefinite"
      />
    </circle>
    <circle cx="230" cy="130" r="20" fill="none" stroke="#E84852" stroke-width="0.5" opacity="0">
      <animate
        attributeName="r"
        values="20;180"
        dur="4.5s"
        begin="4.7s"
        repeatCount="indefinite"
      />
      <animate
        attributeName="opacity"
        values="0.7;0"
        dur="4.5s"
        begin="4.7s"
        repeatCount="indefinite"
      />
    </circle>
  </g>

  <!-- ============================================ -->
  <!-- Guitar strings: 6 horizontal lines, staggered fade-in -->
  <!-- ============================================ -->
  <g stroke="#F2EAD8" stroke-linecap="round">
    <line x1="50" y1="108" x2="390" y2="108" stroke-width="0.35" opacity="0">
      <animate attributeName="opacity" values="0;0.3" dur="0.5s" begin="1.0s" fill="freeze" />
    </line>
    <line x1="50" y1="117" x2="390" y2="117" stroke-width="0.4" opacity="0">
      <animate attributeName="opacity" values="0;0.35" dur="0.5s" begin="1.1s" fill="freeze" />
    </line>
    <line x1="50" y1="125" x2="390" y2="125" stroke-width="0.5" opacity="0">
      <animate attributeName="opacity" values="0;0.4" dur="0.5s" begin="1.2s" fill="freeze" />
    </line>
    <line x1="50" y1="134" x2="390" y2="134" stroke-width="0.5" opacity="0">
      <animate attributeName="opacity" values="0;0.4" dur="0.5s" begin="1.3s" fill="freeze" />
    </line>
    <line x1="50" y1="143" x2="390" y2="143" stroke-width="0.4" opacity="0">
      <animate attributeName="opacity" values="0;0.35" dur="0.5s" begin="1.4s" fill="freeze" />
    </line>
    <line x1="50" y1="152" x2="390" y2="152" stroke-width="0.35" opacity="0">
      <animate attributeName="opacity" values="0;0.3" dur="0.5s" begin="1.5s" fill="freeze" />
    </line>
  </g>

  <!-- ============================================ -->
  <!-- Letter I: slides in diagonally from upper-left -->
  <!-- ============================================ -->
  <g opacity="0">
    <line
      x1="175"
      y1="98"
      x2="175"
      y2="162"
      stroke="#F2EAD8"
      stroke-width="4"
      stroke-linecap="round"
    />
    <line
      x1="163"
      y1="98"
      x2="187"
      y2="98"
      stroke="#F2EAD8"
      stroke-width="3"
      stroke-linecap="round"
    />
    <line
      x1="163"
      y1="162"
      x2="187"
      y2="162"
      stroke="#F2EAD8"
      stroke-width="3"
      stroke-linecap="round"
    />

    <animateTransform
      attributeName="transform"
      type="translate"
      from="-55,-40"
      to="0,0"
      dur="0.9s"
      begin="0.1s"
      fill="freeze"
    />
    <animate attributeName="opacity" values="0;1" dur="0.9s" begin="0.1s" fill="freeze" />
  </g>

  <!-- ============================================ -->
  <!-- Letter Q: drawn via stroke-dashoffset while I is still moving -->
  <!-- ============================================ -->
  <g>
    <circle
      cx="230"
      cy="130"
      r="24"
      fill="none"
      stroke="#F2EAD8"
      stroke-width="3.5"
      stroke-linecap="round"
      stroke-dasharray="151"
      stroke-dashoffset="151"
    >
      <animate
        attributeName="stroke-dashoffset"
        values="151;0"
        dur="0.9s"
        begin="0.6s"
        fill="freeze"
      />
    </circle>
    <line
      x1="244"
      y1="148"
      x2="260"
      y2="166"
      stroke="#F2EAD8"
      stroke-width="3.5"
      stroke-linecap="round"
      stroke-dasharray="25"
      stroke-dashoffset="25"
    >
      <animate
        attributeName="stroke-dashoffset"
        values="25;0"
        dur="0.3s"
        begin="1.4s"
        fill="freeze"
      />
    </line>
  </g>

  <!-- ============================================ -->
  <!-- Red pulse at center of Q (resonance source) -->
  <!-- ============================================ -->
  <circle
    cx="230"
    cy="130"
    r="3"
    fill="#E84852"
    opacity="0"
    style="filter: drop-shadow(0 0 8px rgba(232,72,82,0.85));"
  >
    <animate attributeName="opacity" values="0;0.95" dur="0.4s" begin="1.5s" fill="freeze" />
    <animate
      attributeName="r"
      values="2.8;3.6;2.8"
      dur="1.8s"
      begin="1.9s"
      repeatCount="indefinite"
    />
  </circle>
</svg>
