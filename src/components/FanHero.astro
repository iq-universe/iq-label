---
interface Props {
  size?: number;
  color?: string;
  accentColor?: string;
}

const {
  size = 220,
  color = 'var(--color-text-primary)',
  accentColor = 'var(--color-dancheong-red)',
} = Astro.props;
---

<svg
  width={size}
  height={size * 0.73}
  viewBox="0 0 220 160"
  fill="none"
  aria-label="부채"
  role="img"
  style="filter: drop-shadow(0 0 14px rgba(242, 234, 216, 0.08));"
>
  <g stroke={color} stroke-width="0.6" stroke-linecap="round" opacity="0.7">
    <line x1="110" y1="148" x2="14" y2="78" />
    <line x1="110" y1="148" x2="34" y2="42" />
    <line x1="110" y1="148" x2="68" y2="20" />
    <line x1="110" y1="148" x2="110" y2="12" />
    <line x1="110" y1="148" x2="152" y2="20" />
    <line x1="110" y1="148" x2="186" y2="42" />
    <line x1="110" y1="148" x2="206" y2="78" />
    <path d="M 14 78 Q 110 -22 206 78" stroke-width="0.9" />
    <path d="M 30 90 Q 110 8 190 90" stroke-width="0.4" opacity="0.5" />
    <path d="M 50 100 Q 110 38 170 100" stroke-width="0.3" opacity="0.35" />
  </g>
  <circle
    cx="110"
    cy="148"
    r="4"
    fill={accentColor}
    style="filter: drop-shadow(0 0 8px rgba(232, 72, 82, 0.7));"
  />
  <g fill={accentColor} opacity="0.85">
    <circle cx="68" cy="60" r="1.5" />
    <circle cx="110" cy="48" r="1.5" />
    <circle cx="152" cy="60" r="1.5" />
  </g>
</svg>
