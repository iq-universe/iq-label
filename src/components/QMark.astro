---
interface Props {
  size?: number;
  color?: string;
  withCore?: boolean;
}

const { size = 44, color = 'currentColor', withCore = true } = Astro.props;
---

<svg
  class="qmark"
  width={size}
  height={size}
  viewBox="0 0 72 72"
  fill="none"
  aria-label="Label Q"
  role="img"
>
  <circle class="qmark-aura" cx="33" cy="33" r="25" />

  <g class="qmark-orbit">
    <circle cx="33" cy="33" r="27" stroke="var(--color-dancheong-red)" stroke-width="1" stroke-dasharray="2 10" />
    <circle cx="33" cy="6" r="1.5" fill="var(--color-stardust-gold)" />
  </g>

  <circle class="qmark-ring" cx="33" cy="33" r="23" stroke={color} stroke-width="2.8" />
  <circle class="qmark-groove qmark-groove-outer" cx="33" cy="33" r="15.5" stroke={color} />
  <circle class="qmark-groove qmark-groove-inner" cx="33" cy="33" r="9" stroke={color} />

  <g class="qmark-i" stroke={color} stroke-linecap="round">
    <line x1="33" y1="15" x2="33" y2="50" stroke-width="2.2" />
    <line x1="28" y1="16" x2="38" y2="16" stroke-width="1.8" />
    <line x1="28" y1="50" x2="38" y2="50" stroke-width="1.8" />
  </g>

  <g class="qmark-bars" stroke="var(--color-stardust-gold)" stroke-linecap="round">
    <line class="qmark-bar qmark-bar-1" x1="23" y1="38" x2="23" y2="43" />
    <line class="qmark-bar qmark-bar-2" x1="27" y1="35" x2="27" y2="43" />
    <line class="qmark-bar qmark-bar-3" x1="31" y1="39" x2="31" y2="43" />
  </g>

  {withCore && <circle class="qmark-core" cx="33" cy="33" r="2.3" fill="var(--color-dancheong-red)" />}

  <path
    class="qmark-tail qmark-tail-shadow"
    d="M49 48.5L61 60.5"
    stroke="var(--color-dancheong-red)"
    stroke-width="4"
    stroke-linecap="round"
  />
  <path
    class="qmark-tail"
    d="M47.5 47.5L59.5 59.5"
    stroke={color}
    stroke-width="2.8"
    stroke-linecap="round"
  />

  <path class="qmark-wave qmark-wave-1" d="M56 24C61 28 61 38 56 42" stroke="var(--color-dancheong-red)" />
  <path class="qmark-wave qmark-wave-2" d="M61 19C69 26 69 40 61 47" stroke="var(--color-dancheong-red)" />
</svg>

<style>
  .qmark {
    display: block;
    overflow: visible;
  }

  .qmark-aura {
    fill: rgba(232, 72, 82, 0.1);
    opacity: 0.55;
    transform-origin: 33px 33px;
    animation: qmark-aura 3.6s ease-in-out infinite;
  }

  .qmark-orbit {
    opacity: 0.72;
    transform-box: view-box;
    transform-origin: 33px 33px;
    animation: qmark-orbit 13s linear infinite;
  }

  .qmark-ring,
  .qmark-groove {
    fill: none;
  }

  .qmark-ring {
    filter: drop-shadow(0 0 8px rgba(242, 234, 216, 0.12));
  }

  .qmark-groove {
    opacity: 0.16;
    stroke-width: 0.8;
  }

  .qmark-groove-inner {
    opacity: 0.08;
  }

  .qmark-i {
    opacity: 0.36;
    transform-box: view-box;
    transform-origin: 33px 33px;
    transform: rotate(-18deg);
  }

  .qmark-bars {
    opacity: 0.9;
    stroke-width: 1.6;
  }

  .qmark-bar {
    transform-box: fill-box;
    transform-origin: center bottom;
    animation: qmark-bar-beat 1.1s ease-in-out infinite;
  }

  .qmark-bar-2 {
    animation-delay: 0.16s;
  }

  .qmark-bar-3 {
    animation-delay: 0.32s;
  }

  .qmark-core {
    transform-box: fill-box;
    transform-origin: center;
    filter: drop-shadow(0 0 7px rgba(232, 72, 82, 0.95));
    animation: qmark-core 1.55s ease-in-out infinite;
  }

  .qmark-tail-shadow {
    opacity: 0.18;
  }

  .qmark-tail {
    stroke-dasharray: 18;
    stroke-dashoffset: 0;
    animation: qmark-tail-strum 2.6s ease-in-out infinite;
  }

  .qmark-wave {
    fill: none;
    stroke-linecap: round;
    stroke-width: 1.1;
    opacity: 0;
    animation: qmark-wave 2.6s ease-out infinite;
  }

  .qmark-wave-2 {
    animation-delay: 0.38s;
  }

  @keyframes qmark-orbit {
    to {
      transform: rotate(360deg);
    }
  }

  @keyframes qmark-aura {
    0%, 100% {
      opacity: 0.35;
      transform: scale(0.92);
    }
    50% {
      opacity: 0.72;
      transform: scale(1.04);
    }
  }

  @keyframes qmark-core {
    0%, 100% {
      opacity: 0.78;
      transform: scale(0.9);
    }
    45% {
      opacity: 1;
      transform: scale(1.28);
    }
  }

  @keyframes qmark-bar-beat {
    0%, 100% {
      transform: scaleY(0.45);
    }
    42% {
      transform: scaleY(1.35);
    }
  }

  @keyframes qmark-tail-strum {
    0%, 70%, 100% {
      stroke-dashoffset: 0;
    }
    82% {
      stroke-dashoffset: -7;
    }
  }

  @keyframes qmark-wave {
    0%, 48% {
      opacity: 0;
      transform: translateX(-3px) scale(0.94);
    }
    58% {
      opacity: 0.56;
    }
    100% {
      opacity: 0;
      transform: translateX(3px) scale(1.08);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .qmark-aura,
    .qmark-orbit,
    .qmark-bar,
    .qmark-core,
    .qmark-tail,
    .qmark-wave {
      animation: none;
    }

    .qmark-aura {
      opacity: 0.48;
    }

    .qmark-core {
      opacity: 0.9;
    }
  }
</style>
